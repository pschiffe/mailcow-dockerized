    "autoload": {
        "classmap": [
            "program/actions/",
            "program/include/",
            "program/lib/"
        ]
    },
    "autoload-dev": {
        "classmap": [
            "tests/"
        ]
    },
    "config": {
        "allow-plugins": {
            "ergebnis/composer-normalize": true,
            "phpstan/extension-installer": true,
            "roundcube/plugin-installer": true
        }
    }
